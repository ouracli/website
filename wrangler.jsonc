{
  // Cloudflare Worker serving the ouracli.com static marketing site.
  "name": "ourcli",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "ouracli.com", "custom_domain": true },
    { "pattern": "www.ouracli.com", "custom_domain": true }
  ]
}
